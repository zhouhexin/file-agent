# syntax=docker/dockerfile:1.7

FROM python:3.11-slim

ARG MCP_FILESYSTEM_VERSION=2026.1.14

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app/apps/api \
    FILE_STORAGE_ROOT=/data/uploads \
    LOG_DIR=/data/logs

WORKDIR /app

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update \
    && apt-get install -y --no-install-recommends \
        libreoffice-writer \
        libreoffice-calc \
        ca-certificates \
        nodejs \
        npm \
    && npm install -g "@modelcontextprotocol/server-filesystem@${MCP_FILESYSTEM_VERSION}" \
    && npm cache clean --force \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt /app/requirements.txt

RUN --mount=type=cache,target=/root/.cache/pip \
    python -m pip install --upgrade pip \
    && python -m pip install --prefer-binary -r /app/requirements.txt

COPY . /app

RUN chmod +x /app/deploy/entrypoint.api.sh

EXPOSE 8000

ENTRYPOINT ["/app/deploy/entrypoint.api.sh"]
