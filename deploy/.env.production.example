# File Agent 生产部署环境模板。
# deploy.ps1 会替换带双下划线的占位值；真实 deploy/.env 不得提交到 Git。

CADDY_SITE_ADDRESS=__CADDY_SITE_ADDRESS__
UPLOAD_MAX_SIZE=50MB

POSTGRES_DB=fileAgent
POSTGRES_USER=fileagent_user
POSTGRES_PASSWORD=__POSTGRES_PASSWORD__

JWT_SECRET_KEY=__JWT_SECRET_KEY__
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

LLM_ENABLED=false
LLM_PROVIDER=openai_compatible
LLM_API_KEY=
LLM_BASE_URL=
LLM_CHAT_MODEL=
LLM_TIMEOUT_SECONDS=30
LLM_CLASSIFICATION_MODE=rule_only
LLM_CLASSIFICATION_ALLOW_FREE_PATHS=false

OCR_ENABLED=true
OCR_PADDLE_MODEL_SOURCE=BOS
OCR_LLM_ENABLED=false
OCR_LLM_FALLBACK_QUALITY_THRESHOLD=0.68

DOCLING_ENABLED=true
DOCLING_FORMATS=pdf,docx
DOCLING_OCR_ENABLED=false

# 图谱分类属于可选增强；构建镜像和运行开关必须同时启用。
INSTALL_GRAPH_DEPENDENCIES=false
GRAPH_CLASSIFICATION_ENABLED=false
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
NEO4J_QUERY_TIMEOUT_SECONDS=3
NEO4J_SYNC_ENABLED=false
GRAPH_CLASSIFICATION_MAX_HOPS=1
GRAPH_CLASSIFICATION_TOP_K=8
GRAPH_CLASSIFICATION_MODE=off
GRAPH_EMBEDDING_ENABLED=false
GRAPH_EMBEDDING_PROVIDER=local
GRAPH_EMBEDDING_MODEL_PATH=/models/document-embedding
GRAPH_EMBEDDING_MODEL_NAME=
GRAPH_EMBEDDING_VERSION=document-semantic-v1
GRAPH_EMBEDDING_DIMENSION=384
GRAPH_VECTOR_INDEX_NAME=document_version_embedding_v1
GRAPH_VECTOR_TOP_K=12
GRAPH_VECTOR_MIN_SCORE=0.0
GRAPH_PROJECTION_WORKER_ENABLED=false
GRAPH_PROJECTION_BATCH_SIZE=500
GRAPH_FEEDBACK_COLLECTION_ENABLED=true
GRAPH_CLASSIFICATION_ROLLOUT_PERCENT=10
GRAPH_FEEDBACK_EVAL_MIN_SAMPLES=100
MANAGED_PATH_CLASSIFICATION_PROFILE_DIR=/app/rules/managed-root-classification
MANAGED_PATH_DEFAULT_MODE=NONE
MANAGED_PATH_VECTOR_PILOT_LIMIT=1000
MANAGED_FILE_CLASSIFICATION_SYNC_LIMIT=20
MANAGED_FILE_CLASSIFICATION_BATCH_SIZE=20

# 重命名解析模式：hybrid=Docling 与原生解析字段级仲裁（默认生产模式）；
# native=只使用原生解析器（质量异常时紧急回退）；docling=只使用 Docling（对比测试和问题定位）。
FILE_RENAME_PARSE_MODE=hybrid
# 文件重命名默认使用内置 Native 执行器；F2 必须随离线包部署并固定版本。
FILE_RENAME_EXECUTOR=native
FILE_RENAME_MAX_BATCH_SIZE=20
FILE_RENAME_EXECUTION_TIMEOUT_SECONDS=60
# 重命名差异质量校验：默认关闭模型调用，risk_based 仅校验中高风险建议。
FILE_RENAME_LLM_VALIDATION_ENABLED=false
FILE_RENAME_LLM_VALIDATION_MODE=risk_based
FILE_RENAME_LLM_VALIDATION_THRESHOLD=0.60
FILE_RENAME_LLM_VALIDATION_TIMEOUT_SECONDS=30
FILE_RENAME_LLM_VALIDATION_MAX_ITEMS_PER_BATCH=20
FILE_RENAME_LLM_VALIDATION_PROMPT_VERSION=rename-validation-v1
F2_BINARY_PATH=f2
F2_EXPECTED_VERSION=2.2.2
F2_FALLBACK_TO_NATIVE=false
F2_STDOUT_MAX_BYTES=1048576

LOG_RETENTION_DAYS=7
LOG_LEVEL=INFO

# 服务器受管目录示例：root_key=student_affairs
MANAGED_ROOT_WORKDATA=E:/workdata
# 可选：目录已经按父目录分好类时开启；不配置默认 NONE
MANAGED_ROOT_WORKDATA_CLASSIFICATION_MODE=PATH_AS_CATEGORY
# 可选：显式允许确认后的受管文件重命名；默认 false
MANAGED_ROOT_WORKDATA_ALLOW_RENAME=false
# 只有开启重命名时才改为 rw，并确保宿主机目录已备份
MANAGED_ROOT_VOLUME_MODE=ro
FILESYSTEM_WORKER_POLL_SECONDS=3
