# 复制为 .env 后填写真实密码；.env 不应提交到 Git。
DATABASE_URL=postgresql+psycopg2://fileagent_user:<password>@212.64.14.158:5432/fileAgent
AUTO_CREATE_TABLES=false
FILE_STORAGE_ROOT=./storage/uploads
# 受管原始目录只读入口由 MANAGED_ROOT_<KEY> 配置；以下独立入口只允许归档 worker 追加文件。
MANAGED_ROOT_ARCHIVE_WRITE_PATH=./storage/managed-original/school-files
MANAGED_ROOT_ARCHIVE_ENABLED=true
# Agent 的增删改查全部发生在工作副本目录，删除后的内容进入回收站目录。
WORKING_COPY_STORAGE_ROOT=./storage/working-copies
TRASH_STORAGE_ROOT=./storage/trash
MANAGED_ROOT_WATCH_ENABLED=true
# watcher 是独立进程；这里只控制轻量元数据轮询频率，不在回调中复制或解析文件。
MANAGED_ROOT_WATCH_POLL_SECONDS=2
MANAGED_ROOT_RECONCILE_INTERVAL_SECONDS=300
# 启动时只提交同步任务，不在 API 启动钩子里扫描目录或复制文件。
MANAGED_ROOT_RECONCILE_ON_STARTUP=true
UPLOAD_ARCHIVE_ENABLED=true
UPLOAD_ARCHIVE_RETRY_INTERVAL_SECONDS=300
# 上传附件先异步查重；发现重复或相似候选后必须通过对话逐文件确认。
UPLOAD_DUPLICATE_CHECK_ENABLED=true
UPLOAD_DUPLICATE_SIMILARITY_THRESHOLD=0.90
UPLOAD_DUPLICATE_MAX_CANDIDATES=5
UPLOAD_DUPLICATE_CONFIRMATION_TTL_HOURS=168
# 查重、归档、导入和同步使用持久化任务；并发与 API 请求并发相互独立。
FILESYSTEM_ASYNC_JOBS_ENABLED=true
FILESYSTEM_JOB_LEASE_SECONDS=120
# 每个 worker 进程只领取指定队列；可按下面的运行文档分别启动并限制资源。
FILESYSTEM_WORKER_QUEUES=DUPLICATE_CHECK,ARCHIVE,IMPORT,RECONCILE,FILE_OPERATION
FILESYSTEM_WORKER_ID=filesystem-worker-1
FILESYSTEM_WORKER_POLL_SECONDS=3
ARCHIVE_WORKER_CONCURRENCY=2
IMPORT_WORKER_CONCURRENCY=2
WORKING_COPY_IMPORT_BATCH_SIZE=100
WORKING_COPY_OPERATION_BATCH_SIZE=20
TRASH_RETENTION_DAYS=30
# MVP 必须保持 false；永久删除只能由明确确认的 OperationPlan 驱动。
TRASH_AUTO_PURGE_ENABLED=false
LOG_DIR=./logs
LOG_RETENTION_DAYS=7
LOG_LEVEL=INFO
LLM_ENABLED=false
LLM_PROVIDER=openai_compatible
LLM_API_KEY=
LLM_BASE_URL=
LLM_CHAT_MODEL=
LLM_TIMEOUT_SECONDS=30
LLM_CLASSIFICATION_MODE=rule_only
LLM_CLASSIFICATION_ALLOW_FREE_PATHS=false
# 双摘要默认启用持久化；LLM_ENABLED=false 时使用本地抽取式降级，不会把正文发送到外部服务。
DOCUMENT_SUMMARY_ENABLED=true
DOCUMENT_SUMMARY_PROMPT_VERSION=document-summary-v1
DOCUMENT_SUMMARY_SCHEMA_VERSION=document-summary-schema-v1
LLM_CLASSIFICATION_SUMMARY_ENABLED=true
LLM_CLASSIFICATION_SUMMARY_PROMPT_VERSION=classification-topic-summary-v1
CLASSIFICATION_SUMMARY_SCHEMA_VERSION=classification-topic-summary-schema-v1
# 首次创建工作副本时先完成摘要、分类和命名，再以最终路径原子写入；这不是后续重命名。
INITIAL_WORKING_COPY_ORGANIZATION_ENABLED=true
# 主分类达到阈值且有原文证据时进入分类目录，否则进入内部“待整理”目录并保持可检索。
INITIAL_ORGANIZATION_CONFIDENCE=0.60
DOCLING_ENABLED=true
DOCLING_FORMATS=pdf,docx
DOCLING_OCR_ENABLED=true

# 旧版 .doc 首次读取时转换为持久化 .docx 派生件；后续解析、分类和重命名复用该派生件。
LEGACY_OFFICE_CONVERSION_ENABLED=true
LEGACY_OFFICE_CONVERTER=libreoffice
# 可留空自动发现；Windows 可填 C:\Program Files\LibreOffice\program\soffice.com，
# macOS 可填 /Applications/LibreOffice.app/Contents/MacOS/soffice，Linux 可填 /usr/bin/soffice。
LIBREOFFICE_EXECUTABLE=
LEGACY_OFFICE_CONVERSION_TIMEOUT_SECONDS=90
LEGACY_OFFICE_MAX_FILE_SIZE_MB=100
LEGACY_OFFICE_DERIVATIVE_DIR=derivatives/office

# Docling 使用预下载的本地模型目录；部署时按实际挂载路径调整。
DOCLING_ARTIFACTS_PATH=/opt/file-agent/models/docling
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
HF_HUB_DISABLE_TELEMETRY=1

# Neo4j 文件知识图谱配置（这里的 GRAPH 不是 LangGraph）：
# PostgreSQL 仍是文件、分类、反馈等业务事实的唯一事实源；Neo4j 只保存可重建的图投影，
# 用于关系候选扩展、相似文件召回和分类重排。Neo4j 不可用时应降级到基础分类链路。
# 启用前需安装 requirements-graph.txt、保证 Neo4j 可连接，并完成首次图投影同步。
# 图谱分类总开关。false 时不访问 Neo4j，也不执行图谱分类增强。
GRAPH_CLASSIFICATION_ENABLED=false
# Neo4j Bolt 连接地址、账号、密码和数据库名；生产环境必须替换示例密码。
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=12345678
NEO4J_DATABASE=neo4j
# 单次 Neo4j 查询超时时间（秒），超时后应走降级逻辑，不能阻塞基础文件能力。
NEO4J_QUERY_TIMEOUT_SECONDS=3
# 是否在 API 启动时把 PostgreSQL 中的事实同步为 Neo4j 投影；false 时需通过同步命令显式同步。
NEO4J_SYNC_ENABLED=false
# 关系候选扩展的最大跳数，当前实现限制为 1～2 跳；跳数越大，候选越多、查询成本越高。
GRAPH_CLASSIFICATION_MAX_HOPS=1
# 图谱分类候选数量上限，当前实现限制为 1～20。
GRAPH_CLASSIFICATION_TOP_K=8
# 图谱分类运行模式：off=关闭；shadow=执行并记录对比但仍返回基础结果；
# enabled=允许返回图谱增强结果。仅设置 GRAPH_CLASSIFICATION_ENABLED=true 仍不足以启用增强。
GRAPH_CLASSIFICATION_MODE=off
# 是否启用 Neo4j 向量相似文件召回；必须同时开启图谱分类、使用非 off 模式并配置本地模型。
GRAPH_EMBEDDING_ENABLED=false
# 向量模型提供方。当前只支持 local，表示只读取本地模型，不把文件正文发送到外部服务。
GRAPH_EMBEDDING_PROVIDER=local
# sentence-transformers 本地模型目录；启用图向量能力时必须填写存在且可读的目录。
GRAPH_EMBEDDING_MODEL_PATH=
# 模型的稳定名称，仅用于配置标识和审计；实际模型仍从 GRAPH_EMBEDDING_MODEL_PATH 加载。
GRAPH_EMBEDDING_MODEL_NAME=
# 向量生成规则版本。更换模型、切分方式或语义规则后应递增，避免复用旧向量。
GRAPH_EMBEDDING_VERSION=document-semantic-v1
# 向量维度，必须与本地模型输出及 Neo4j 向量索引维度一致。
GRAPH_EMBEDDING_DIMENSION=384
# Neo4j 中用于文件版本向量检索的索引名称。
GRAPH_VECTOR_INDEX_NAME=document_version_embedding_v1
# 每次语义召回的相似文件候选上限，当前实现限制为 1～50。
GRAPH_VECTOR_TOP_K=12
# 语义召回最低相似度，范围为 0～1；0.0 表示当前不按分数过滤。
GRAPH_VECTOR_MIN_SCORE=0.0
# 后台持续投影 Worker 的预留开关；当前尚未接入运行时，设置为 true 不会自动启动 Worker。
GRAPH_PROJECTION_WORKER_ENABLED=false
# 图投影同步与向量生成命令的单批处理数量，当前实现限制为 1～5000。
GRAPH_PROJECTION_BATCH_SIZE=500
# 是否允许收集用户对分类建议的接受、拒绝和修正反馈；它不会自动开启图谱分类。
GRAPH_FEEDBACK_COLLECTION_ENABLED=true
# enabled 模式下按用户稳定分桶启用图谱增强的比例；未命中的用户仍按 shadow 模式运行。
GRAPH_CLASSIFICATION_ROLLOUT_PERCENT=10
# 图谱分类评估达到“样本充足”所需的最少反馈数，不影响反馈的正常收集。
GRAPH_FEEDBACK_EVAL_MIN_SAMPLES=100
MANAGED_PATH_CLASSIFICATION_PROFILE_DIR=./rules/managed-root-classification
MANAGED_PATH_DEFAULT_MODE=NONE
MANAGED_PATH_VECTOR_PILOT_LIMIT=1000
MANAGED_FILE_CLASSIFICATION_SYNC_LIMIT=20
MANAGED_FILE_CLASSIFICATION_BATCH_SIZE=20

# 重命名解析模式：hybrid=Docling 与原生解析字段级仲裁（默认生产模式）；
# native=只使用原生解析器（质量异常时紧急回退）；docling=只使用 Docling（对比测试和问题定位）。
FILE_RENAME_PARSE_MODE=hybrid
# 文件重命名默认继续使用 Native 执行器；只有离线部署并校验固定 F2 二进制后才切换为 f2。
FILE_RENAME_EXECUTOR=native
FILE_RENAME_MAX_BATCH_SIZE=20
FILE_RENAME_EXECUTION_TIMEOUT_SECONDS=60
# 重命名差异质量校验：默认关闭模型调用，risk_based 仅校验中高风险建议。
FILE_RENAME_LLM_VALIDATION_ENABLED=false
FILE_RENAME_LLM_VALIDATION_MODE=risk_based
FILE_RENAME_LLM_VALIDATION_THRESHOLD=0.60
FILE_RENAME_LLM_VALIDATION_TIMEOUT_SECONDS=30
FILE_RENAME_LLM_VALIDATION_MAX_ITEMS_PER_BATCH=20
FILE_RENAME_LLM_VALIDATION_PROMPT_VERSION=rename-validation-v1
F2_BINARY_PATH=f2
F2_EXPECTED_VERSION=2.2.2
F2_FALLBACK_TO_NATIVE=false
F2_STDOUT_MAX_BYTES=1048576
